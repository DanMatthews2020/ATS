generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // transaction pooler — used at runtime
  directUrl = env("DIRECT_URL")     // session pooler — used by prisma migrate
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  HR
  MANAGER
  INTERVIEWER
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  ON_HOLD
}

enum CandidateSource {
  REFERRAL
  JOB_BOARD
  DIRECT
  AGENCY
  AI_SOURCED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum InterviewType {
  PHONE
  VIDEO
  ON_SITE
  TECHNICAL
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum OfferStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum OnboardingCategory {
  HR
  IT
  MANAGER
  NEW_HIRE
}

enum LegalBasis {
  LEGITIMATE_INTERESTS
  CONSENT
  CONTRACT
}

enum RetentionStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  ANONYMISED
}

enum RequestType {
  SAR
  ERASURE
  PORTABILITY
  RECTIFICATION
  OBJECTION
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  FULFILLED
  REJECTED
  OVERDUE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(HR)
  firstName    String
  lastName     String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdJobs           JobPosting[]          @relation("CreatedBy")
  jobMemberships        JobMember[]
  interviewSlots        InterviewsOnUsers[]
  assignedTasks         OnboardingTask[]      @relation("AssignedTo")
  employee              Employee?             @relation("UserEmployee")
  refreshTokens         RefreshToken[]
  workflowTemplates     WorkflowTemplate[]    @relation("WorkflowCreatedBy")
  scorecards            Scorecard[]           @relation("ScorecardCreatedBy")
  evaluationsSubmitted  CandidateEvaluation[] @relation("EvaluationSubmittedBy")
  followUpsCreated      FollowUp[]            @relation("FollowUpCreatedBy")
  emailTemplates        EmailTemplate[]       @relation("EmailTemplateCreatedBy")
  projectsCreated       Project[]             @relation("ProjectCreatedBy")
  projectCandidatesAdded ProjectCandidate[]   @relation("ProjectCandidateAddedBy")
  projectNotesCreated   ProjectNote[]         @relation("ProjectNoteCreatedBy")
  sequencesCreated      Sequence[]            @relation("SequenceCreatedBy")
  feedbackFormsCreated  FeedbackForm[]        @relation("FeedbackFormCreatedBy")
  feedbackSubmissions   FeedbackSubmission[]  @relation("FeedbackSubmittedBy")
  notifications         Notification[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model JobPosting {
  id           String     @id @default(uuid())
  title        String
  department   String
  location     String
  type         JobType
  status       JobStatus  @default(DRAFT)
  description  String
  requirements String?
  salaryMin    Decimal?   @db.Decimal(12, 2)
  salaryMax    Decimal?   @db.Decimal(12, 2)
  openedAt     DateTime?
  closedAt     DateTime?
  createdById  String
  createdBy    User       @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  applications     Application[]
  workflowTemplate WorkflowTemplate?
  evaluations      CandidateEvaluation[]
  members          JobMember[]
}

model JobMember {
  id      String   @id @default(uuid())
  jobId   String
  userId  String
  role    String   @default("HIRING_MANAGER")
  addedAt DateTime @default(now())
  job     JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

model Candidate {
  id                 String          @id @default(uuid())
  firstName          String
  lastName           String
  email              String          @unique
  phone              String?
  cvUrl              String?
  linkedInUrl        String?
  source             CandidateSource @default(JOB_BOARD)
  skills             String[]
  tags               String[]
  location           String?
  currentCompany     String?
  doNotContact       Boolean         @default(false)
  doNotContactReason String?
  doNotContactNote   String?
  doNotContactAt     DateTime?
  deletedAt          DateTime?
  deletedBy          String?
  deletedReason      String?         // 'RETENTION_EXPIRED' | 'ERASURE_REQUEST' | 'MANUAL'
  isAnonymised       Boolean         @default(false)
  anonymisedAt       DateTime?
  legalBasis           LegalBasis    @default(LEGITIMATE_INTERESTS)
  privacyNoticeSentAt  DateTime?
  privacyNoticeSentBy  String?
  consentGivenAt       DateTime?
  consentScope         String?
  retentionExpiresAt   DateTime?
  retentionNote        String?
  retentionStatus      RetentionStatus @default(ACTIVE)
  lastActivityAt       DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  applications        Application[]
  employee            Employee?
  notes               CandidateNote[]
  evaluations         CandidateEvaluation[]
  followUps           FollowUp[]
  projectCandidates   ProjectCandidate[]
  sequenceEnrollments SequenceEnrollment[]
  feedbackSubmissions FeedbackSubmission[]
  referrals           Referral[]
  rightsRequests      CandidateRightsRequest[]
}

model Application {
  id           String            @id @default(uuid())
  candidateId  String
  candidate    Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  status       ApplicationStatus @default(APPLIED)
  stage        String?
  notes        String?
  appliedAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  interviews          Interview[]
  offer               Offer?
  candidateNotes      CandidateNote[]
  feedbackSubmissions FeedbackSubmission[]

  @@unique([candidateId, jobPostingId])
}

model Interview {
  id            String          @id @default(uuid())
  applicationId String
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduledAt   DateTime
  duration      Int             // minutes
  type          InterviewType
  status        InterviewStatus @default(SCHEDULED)
  feedback      String?
  rating        Int?            // 1–5
  recommendation String?        // 'hire' | 'no-hire' | 'maybe'
  meetingLink   String?
  location      String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  interviewers InterviewsOnUsers[]
}

model InterviewsOnUsers {
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([interviewId, userId])
}

model Offer {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  salary        Decimal     @db.Decimal(12, 2)
  currency      String      @default("USD")
  status        OfferStatus @default(DRAFT)
  sentAt        DateTime?
  expiresAt     DateTime?
  acceptedAt    DateTime?
  respondedAt   DateTime?
  startDate     DateTime?
  equity        String?
  benefits      String?
  createdBy     String?
  signatureUrl  String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Employee {
  id             String         @id @default(uuid())
  userId         String?        @unique
  user           User?          @relation("UserEmployee", fields: [userId], references: [id])
  candidateId    String?        @unique
  candidate      Candidate?     @relation(fields: [candidateId], references: [id])
  employeeNumber String         @unique
  department     String
  jobTitle       String
  managerId      String?
  manager        Employee?      @relation("Reports", fields: [managerId], references: [id])
  reports        Employee[]     @relation("Reports")
  startDate      DateTime
  employmentType EmploymentType
  workLocation   String?
  status         EmployeeStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  onboardingTasks OnboardingTask[]
}

model OnboardingTask {
  id           String             @id @default(uuid())
  employeeId   String
  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title        String
  category     OnboardingCategory
  status       TaskStatus         @default(TODO)
  assignedToId String?
  assignedTo   User?              @relation("AssignedTo", fields: [assignedToId], references: [id])
  dueDate      DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model CandidateNote {
  id            String       @id @default(uuid())
  candidateId   String
  candidate     Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  content       String
  authorName    String       @default("Recruiter")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model WorkflowTemplate {
  id          String          @id @default(uuid())
  jobId       String          @unique
  jobPosting  JobPosting      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String          @default("Interview Workflow")
  createdById String
  createdBy   User            @relation("WorkflowCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  stages WorkflowStage[]
}

model WorkflowStage {
  id                String           @id @default(uuid())
  workflowId        String
  workflow          WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stageName         String
  stageType         String           // phone-screen | video-call | on-site | take-home | offer | hired
  description       String?
  position          Int
  requiresScorecard Boolean          @default(false)
  scorecardId       String?
  scorecard         Scorecard?       @relation("StageScorecard", fields: [scorecardId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  evaluations CandidateEvaluation[]
}

model Scorecard {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdById String
  createdBy   User     @relation("ScorecardCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  criteria    ScorecardCriterion[]
  stages      WorkflowStage[]      @relation("StageScorecard")
  evaluations CandidateEvaluation[]
}

model ScorecardCriterion {
  id               String    @id @default(uuid())
  scorecardId      String
  scorecard        Scorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  name             String
  type             String    // rating | yes-no | free-text | multiple-choice
  description      String?
  isRequired       Boolean   @default(true)
  position         Int
  allowNotes       Boolean   @default(false)
  notesLabel       String    @default("Notes")
  notesPlaceholder String?
  notesRequired    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  responses EvaluationResponse[]
}

model CandidateEvaluation {
  id                    String         @id @default(uuid())
  candidateId           String
  candidate             Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId                 String
  jobPosting            JobPosting     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stageId               String?
  stage                 WorkflowStage? @relation(fields: [stageId], references: [id])
  scorecardId           String?
  scorecard             Scorecard?     @relation(fields: [scorecardId], references: [id])
  submittedById         String
  submittedBy           User           @relation("EvaluationSubmittedBy", fields: [submittedById], references: [id])
  overallRecommendation String?        // strong-yes | yes | no | strong-no
  notes                 String?
  status                String         @default("pending") // pending | in-progress | submitted
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  responses EvaluationResponse[]
}

model EvaluationResponse {
  id            String              @id @default(uuid())
  evaluationId  String
  evaluation    CandidateEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criterionId   String
  criterion     ScorecardCriterion  @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  responseValue String
  responseNotes String              @default("")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model FollowUp {
  id           String    @id @default(uuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  followUpDate DateTime
  note         String?
  isCompleted  Boolean   @default(false)
  createdById  String
  createdBy    User      @relation("FollowUpCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Email Templates ──────────────────────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("custom") // outreach | follow-up | interview | offer | rejection | onboarding | custom
  subject     String
  body        String
  isShared    Boolean  @default(true)
  createdById String
  createdBy   User     @relation("EmailTemplateCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sequenceSteps SequenceStep[]
}

// ─── Projects ─────────────────────────────────────────────────────────────────

enum ProjectVisibility {
  PRIVATE
  TEAM
}

model Project {
  id          String            @id @default(uuid())
  name        String
  description String?
  category    String            @default("talent-pool") // talent-pool | longlist | event | campaign | custom
  visibility  ProjectVisibility @default(TEAM)
  tags        String[]
  createdById String
  createdBy   User              @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  candidates ProjectCandidate[]
  notes      ProjectNote[]
}

model ProjectCandidate {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  addedById   String
  addedBy     User      @relation("ProjectCandidateAddedBy", fields: [addedById], references: [id])
  notes       String?
  addedAt     DateTime  @default(now())

  @@unique([projectId, candidateId])
}

model ProjectNote {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  content     String
  createdById String
  createdBy   User     @relation("ProjectNoteCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Email Sequences ──────────────────────────────────────────────────────────

enum SequenceStatus {
  ACTIVE
  PAUSED
}

enum SequenceStepType {
  EMAIL
  WAIT
  TASK
}

enum EnrollmentStatus {
  ACTIVE      // legacy alias kept for existing rows
  ENROLLED    // just enrolled, not yet started
  IN_PROGRESS // actively sending
  COMPLETED   // all steps sent
  REPLIED     // candidate replied
  INTERESTED  // recruiter marked interested
  CONVERTED   // became an application
  STOPPED     // manually stopped or DNC
}

model Sequence {
  id              String         @id @default(uuid())
  name            String
  status          SequenceStatus @default(ACTIVE)
  senderEmail     String?
  linkedJobId     String?
  stopOnReply     Boolean        @default(true)
  stopOnInterview Boolean        @default(true)
  stopOnHired     Boolean        @default(false)
  skipWeekends    Boolean        @default(true)
  isShared        Boolean        @default(false)
  maxEmails       Int            @default(10)
  sendingDays     String[]       @default(["Mon", "Tue", "Wed", "Thu", "Fri"])
  createdById     String
  createdBy       User           @relation("SequenceCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
}

model SequenceStep {
  id              String           @id @default(uuid())
  sequenceId      String
  sequence        Sequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  position        Int
  type            SequenceStepType
  subject         String?
  body            String?
  templateId      String?
  template        EmailTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  waitDays        Int?
  delayDays       Int              @default(0)
  taskDescription String?
  sendTime        String?          @default("09:00")
  sendFrom        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SequenceEnrollment {
  id            String           @id @default(uuid())
  sequenceId    String
  sequence      Sequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  currentStep   Int              @default(0)
  status        EnrollmentStatus @default(ACTIVE)
  sendFrom      String?
  startDate     DateTime         @default(now())
  response      String?
  opens         Int              @default(0)
  clicks        Int              @default(0)
  enrolledAt    DateTime         @default(now())
  completedAt   DateTime?
  stoppedAt     DateTime?
  stoppedReason String?

  @@unique([sequenceId, candidateId])
}

// ─── Feedback Forms ───────────────────────────────────────────────────────────

model FeedbackForm {
  id          String   @id @default(uuid())
  name        String
  stage       String?
  questions   Json     @default("[]")
  createdById String
  createdBy   User     @relation("FeedbackFormCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions FeedbackSubmission[]
}

model FeedbackSubmission {
  id             String       @id @default(uuid())
  formId         String
  form           FeedbackForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  candidateId    String
  candidate      Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applicationId  String?
  application    Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  submittedById  String
  submittedBy    User         @relation("FeedbackSubmittedBy", fields: [submittedById], references: [id])
  answers        Json         @default("{}")
  overallRating  Int?
  recommendation String?
  submittedAt    DateTime     @default(now())
}

// ─── Referrals ─────────────────────────────────────────────────────────────────

model Referral {
  id              String    @id @default(uuid())
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  referredByName  String
  referredByEmail String?
  relationship    String    // former-colleague | friend | university | professional-network | other
  jobId           String?
  jobTitle        String?
  note            String?
  referralDate    DateTime  @default(now())
  createdAt       DateTime  @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actorEmail   String?
  actorRole    String?
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([createdAt])
}

model CandidateRightsRequest {
  id              String        @id @default(cuid())
  candidateId     String?
  requesterEmail  String
  requestType     RequestType
  status          RequestStatus @default(OPEN)
  receivedAt      DateTime
  dueAt           DateTime
  fulfilledAt     DateTime?
  fulfilledBy     String?
  notes           String?
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PerformanceCycle {
  id          String              @id @default(cuid())
  name        String
  cycleType   String
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  status      String              @default("upcoming")
  createdAt   DateTime            @default(now())
  reviews     PerformanceReview[]
}

model PerformanceReview {
  id           String           @id @default(cuid())
  cycleId      String
  cycle        PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId   String
  reviewerId   String
  status       String           @default("not_started")
  scores       Json?
  overallScore Float?
  notes        String?
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
}

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String?
  ownerId     String
  scope       String    @default("individual")
  progress    Int       @default(0)
  status      String    @default("on_track")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
}

model ReportRun {
  id         String   @id @default(cuid())
  reportKey  String
  reportName String
  category   String
  runById    String
  runAt      DateTime @default(now())
  format     String   @default("csv")
  status     String   @default("processing")
  fileUrl    String?
}

model ReportSchedule {
  id         String   @id @default(cuid())
  reportKey  String
  reportName String
  frequency  String
  nextRunAt  DateTime
  recipients String[]
  createdAt  DateTime @default(now())
}

model RopaEntry {
  id                  String    @id @default(cuid())
  processingActivity  String
  purpose             String
  legalBasis          String
  dataCategories      String[]
  dataSubjects        String
  recipients          String
  retentionPeriod     String
  securityMeasures    String
  transfersOutsideEEA Boolean   @default(false)
  transferMechanism   String?
  lastReviewedAt      DateTime?
  lastReviewedBy      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model RejectionReason {
  id          String   @id @default(cuid())
  label       String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
